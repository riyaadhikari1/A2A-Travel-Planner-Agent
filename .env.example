# APP
APP_NAME=A2A Travel
APP_VERSION=0.1.0
ENV=development
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0

# PORTS
GATEWAY_PORT=8000
WEATHER_AGENT_PORT=8001
DOMESTIC_FLIGHT_AGENT_PORT=8002
INTL_FLIGHT_AGENT_PORT=8003
HOTEL_AGENT_PORT=8004
BUDGET_AGENT_PORT=8005

# AGENT ENDPOINTS
WEATHER_AGENT_URL=http://localhost:8001
DOMESTIC_FLIGHT_AGENT_URL=http://localhost:8002
INTL_FLIGHT_AGENT_URL=http://localhost:8003
HOTEL_AGENT_URL=http://localhost:8004
BUDGET_AGENT_URL=http://localhost:8005

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LLM — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=openai/gpt-4o-mini
TEMPERATURE=0.1
MAX_TOKENS=2048

# REDIS — leave empty to use MemoryStore (no Redis needed for development)
REDIS_URL=
REDIS_TTL=3600

# POSTGRESQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/a2a_travel

# TIMEOUTS
DEFAULT_TIMEOUT=30.0

# EXTERNAL AGENT APIS
SERPER_API_KEY=your_serper_api_key_here        # https://serper.dev — hotel search
TRIPTURBO_DOMESTIC_API=https://live.tripturbo.com/domestic/v3/search/
ESEWA_INTL_API=https://esewatravels.com/least-fare-prices
DEFAULT_NATIONALITY=NP